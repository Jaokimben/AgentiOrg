{
  "version": 2,
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "vite",
  "env": [
    {
      "key": "DATABASE_URL",
      "description": "MySQL/TiDB database connection string"
    },
    {
      "key": "JWT_SECRET",
      "description": "Session cookie signing secret"
    },
    {
      "key": "VITE_APP_ID",
      "description": "Manus OAuth application ID"
    },
    {
      "key": "OAUTH_SERVER_URL",
      "description": "Manus OAuth backend base URL"
    },
    {
      "key": "VITE_OAUTH_PORTAL_URL",
      "description": "Manus login portal URL (frontend)"
    },
    {
      "key": "OWNER_OPEN_ID",
      "description": "Owner's Manus OpenID"
    },
    {
      "key": "OWNER_NAME",
      "description": "Owner's name"
    },
    {
      "key": "BUILT_IN_FORGE_API_URL",
      "description": "Manus built-in APIs URL (server-side)"
    },
    {
      "key": "BUILT_IN_FORGE_API_KEY",
      "description": "Bearer token for Manus built-in APIs (server-side)"
    },
    {
      "key": "VITE_FRONTEND_FORGE_API_URL",
      "description": "Manus built-in APIs URL (frontend)"
    },
    {
      "key": "VITE_FRONTEND_FORGE_API_KEY",
      "description": "Bearer token for frontend access to Manus built-in APIs"
    },
    {
      "key": "VITE_ANALYTICS_ENDPOINT",
      "description": "Analytics endpoint URL"
    },
    {
      "key": "VITE_ANALYTICS_WEBSITE_ID",
      "description": "Analytics website ID"
    },
    {
      "key": "VITE_APP_TITLE",
      "description": "Application title"
    },
    {
      "key": "VITE_APP_LOGO",
      "description": "Application logo URL"
    }
  ],
  "buildOutputDirectory": "dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/_core/index.ts",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/client/index.html"
    }
  ]
}
