# Database Configuration
# MySQL/TiDB connection string
# Example: mysql://user:password@host:port/database
DATABASE_URL=mysql://username:password@hostname:3306/database_name

# Authentication & Security
# Generate a random secret for JWT signing (use: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# Manus OAuth Configuration (Backend)
OAUTH_SERVER_URL=https://api.manus.im
BUILT_IN_FORGE_API_URL=https://api.manus.im
BUILT_IN_FORGE_API_KEY=your-backend-api-key

# Manus OAuth Configuration (Frontend)
VITE_APP_ID=your-manus-app-id
VITE_OAUTH_PORTAL_URL=https://auth.manus.im
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im
VITE_FRONTEND_FORGE_API_KEY=your-frontend-api-key

# Owner Configuration
OWNER_OPEN_ID=your-manus-open-id
OWNER_NAME=Your Organization Name

# Application Configuration
VITE_APP_TITLE=AgentiOrg
VITE_APP_LOGO=https://your-domain.com/logo.png

# Analytics (Optional)
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your-analytics-website-id

# Node Environment (automatically set by Vercel)
# NODE_ENV=production
